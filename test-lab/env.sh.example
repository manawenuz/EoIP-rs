#!/bin/bash
# EoIP-rs Performance Test Lab — Environment Template
#
# Copy to env.sh and fill in your VM IPs:
#   cp test-lab/env.sh.example test-lab/env.sh
#   # edit test-lab/env.sh with your IPs
#   source test-lab/env.sh
#
# env.sh is gitignored — it won't be committed.

export NODE1_IP="<build-vm-ipv4>"
export NODE2_IP="<test-vm-ipv4>"

export NODE1_TUNNEL_IP="10.200.0.1"
export NODE2_TUNNEL_IP="10.200.0.2"

export HCLOUD_LOCATION="fsn1"
export HCLOUD_SERVER_TYPE="cpx22"
export HCLOUD_IMAGE="ubuntu-22.04"

export REMOTE_NEW_DIR="/opt/eoip-new"
export REMOTE_OLD_DIR="/opt/eoip-old"
export REMOTE_CONFIG="/etc/eoip-rs/config.toml"
export REMOTE_SCRIPTS="/opt"
export REMOTE_BUILD_DIR="/root/EoIP-rs"

export TUNNEL_ID=100
export TUNNEL_IFACE="eoip100"
export TUNNEL_MTU=1500

export BENCH_DURATION=15
export BENCH_IPERF_PORT=5201
